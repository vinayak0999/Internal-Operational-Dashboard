# ============================================================
# Encord Operations Dashboard — Environment Config
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Path to your Encord SSH private key
# Use the Accelerate admin key — covers ALL client workspaces
ENCORD_SSH_KEY_PATH=/path/to/your/encord-private-key.ed25519

# Encord API domain
# EU platform: https://api.encord.com
# US platform: https://api.us.encord.com
ENCORD_DOMAIN=https://api.encord.com

# Project hashes — leave EMPTY to auto-discover ALL projects from the SSH key
ENCORD_PROJECT_HASHES=

# Outlier thresholds
REJECTION_RATE_MARGIN=0.10
TPT_LOW_THRESHOLD=0.20
TPT_HIGH_THRESHOLD=0.50
THROUGHPUT_LOW_THRESHOLD=0.20

# Sync: every 2 minutes with incremental (unchanged projects skipped instantly)
SYNC_INTERVAL_MINUTES=2
MAX_PARALLEL_SYNCS=5
INCREMENTAL_SYNC=true
STALE_DATA_MINUTES=5
